{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "./scripts",
    "outDir": "./dist"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}